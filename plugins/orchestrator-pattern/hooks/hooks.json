{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^(Bash|Read|read_file|shell|exec_command|functions\\.exec)$",
        "hooks": [
          {
            "type": "command",
            "command": "\"$PLUGIN_ROOT/scripts/delegation-guard.sh\"",
            "timeout": 5,
            "statusMessage": "Checking delegation threshold"
          }
        ]
      }
    ]
  }
}
